# Copy this file to `.env` in the project root before starting the app.
#
# You can find these values in the Supabase dashboard:
# Project Settings -> API

# Your Supabase project URL.
# Example: https://abcd1234efgh.supabase.co
VITE_SUPABASE_URL=

# Your Supabase anon/public key.
# This frontend app expects the publishable client key here.
VITE_SUPABASE_PUBLISHABLE_KEY=
